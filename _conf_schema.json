{
  "save_root": {
    "type": "string",
    "description": "文件保存根目录",
    "hint": "支持本地路径或 NAS 挂载路径，留空则使用 AstrBot 默认数据目录",
    "default": "data/plugin_data/astrbot_plugin_nas"
  },
  "admin_users": {
    "type": "list",
    "description": "管理员列表",
    "hint": "填写可管理 NAS 助手的用户 ID",
    "default": []
  },
  "allow_group_commands": {
    "type": "bool",
    "description": "允许群聊命令",
    "hint": "关闭时所有文件管理命令只能私聊使用",
    "default": false
  },
  "max_file_size": {
    "type": "int",
    "description": "单文件大小上限 (MB)",
    "default": 2048,
    "minimum": 1,
    "maximum": 10240
  },
  "auto_save_enabled": {
    "type": "bool",
    "description": "启用自动保存",
    "hint": "关闭后只响应指令，不自动保存文件",
    "default": true
  },
  "dedup_enabled": {
    "type": "bool",
    "description": "启用文件去重 (MD5)",
    "default": true
  },
  "delete_confirm_ttl": {
    "type": "int",
    "description": "删除确认超时 (秒)",
    "default": 120,
    "minimum": 10,
    "maximum": 600
  },
  "log_enabled": {
    "type": "bool",
    "description": "启用操作日志",
    "default": true
  },
  "preview_text_chars": {
    "type": "int",
    "description": "文本预览最大字符数",
    "default": 1200,
    "minimum": 100,
    "maximum": 10000
  },
  "path_import_max_files": {
    "type": "int",
    "description": "路径导入单次最大文件数",
    "hint": "/addpath 可从任意本机路径或 NAS 挂载路径导入，目录过大时按此上限截断",
    "default": 2000,
    "minimum": 1,
    "maximum": 100000
  },
  "auto_repair_interval_minutes": {
    "type": "int",
    "description": "后台一致性检查间隔 (分钟)",
    "hint": "0 表示关闭；开启后会定期从文件系统修复索引",
    "default": 0,
    "minimum": 0,
    "maximum": 10080
  },
  "categories": {
    "type": "text",
    "description": "自定义分类规则 (JSON)",
    "hint": "留空使用默认分类。格式: {\"分类名\": [\"扩展名1\",\"扩展名2\"]}",
    "default": ""
  }
}
