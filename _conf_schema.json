{
  "save_root": {
    "type": "string",
    "description": "文件保存根目录",
    "hint": "支持本地路径或 NAS 挂载路径，留空则使用 AstrBot 默认数据目录",
    "default": ""
  },
  "allowed_users": {
    "type": "list",
    "description": "允许使用的 QQ 列表",
    "hint": "留空则所有用户可用",
    "default": []
  },
  "admin_users": {
    "type": "list",
    "description": "管理员列表",
    "hint": "仅管理员可删除、移动文件",
    "default": []
  },
  "max_file_size": {
    "type": "int",
    "description": "单文件大小上限 (MB)",
    "default": 2048,
    "minimum": 1,
    "maximum": 10240
  },
  "auto_save_enabled": {
    "type": "bool",
    "description": "启用自动保存",
    "hint": "关闭后只响应指令，不自动保存文件",
    "default": true
  },
  "dedup_enabled": {
    "type": "bool",
    "description": "启用文件去重 (MD5)",
    "default": true
  },
  "delete_confirm_ttl": {
    "type": "int",
    "description": "删除确认超时 (秒)",
    "default": 120,
    "minimum": 10,
    "maximum": 600
  },
  "log_enabled": {
    "type": "bool",
    "description": "启用操作日志",
    "default": true
  },
  "categories": {
    "type": "text",
    "description": "自定义分类规则 (JSON)",
    "hint": "留空使用默认分类。格式: {\"分类名\": [\"扩展名1\",\"扩展名2\"]}",
    "default": ""
  }
}
